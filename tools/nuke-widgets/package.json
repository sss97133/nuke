{
  "name": "@nuke1/widgets",
  "version": "0.2.0",
  "description": "Embeddable Web Component widgets for the Nuke vehicle data platform",
  "type": "module",
  "main": "dist/nuke-widgets.js",
  "module": "dist/nuke-widgets.js",
  "exports": {
    ".": {
      "import": "./dist/nuke-widgets.js"
    },
    "./vehicle": {
      "import": "./dist/widgets/nuke-vehicle.js"
    },
    "./vision": {
      "import": "./dist/widgets/nuke-vision.js"
    },
    "./valuation": {
      "import": "./dist/widgets/nuke-valuation.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "preview": "vite preview --open test/index.html"
  },
  "keywords": [
    "nuke",
    "vehicle",
    "widgets",
    "web-components",
    "embeddable"
  ],
  "author": "Nuke Team",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.3.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.75.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
